# Copy to .env and fill in. These are read SERVER-SIDE by the API routes
# (Vercel serverless functions in prod; the Vite dev middleware locally).
# The VITE_ names are accepted too, so existing setups keep working.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Google sign-in gate (Fluxco standard) ---
# Leave GOOGLE_CLIENT_ID UNSET locally so the app runs auth-off (no-op gate).
# Set it (Production scope) in Vercel to turn the gate ON. Redeploy to take effect.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# FLUXCO_ALLOWED_DOMAIN=fluxco.com                 # optional; this is the default
# FLUXCO_ALLOWED_EMAILS=alice@fluxco.com,bob@fluxco.com  # optional; restrict to specific people
